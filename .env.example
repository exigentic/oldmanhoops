# Supabase
# Keys below are the modern sb_publishable_* / sb_secret_* format.
# NEXT_PUBLIC_SUPABASE_ANON_KEY holds the publishable key (client-safe).
# SUPABASE_SERVICE_ROLE_KEY holds the secret key (server-side only, never exposed to the browser).
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:55321
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_replace_me
SUPABASE_SERVICE_ROLE_KEY=sb_secret_replace_me

# Resend
RESEND_API_KEY=re_replace_me

# Magic link HMAC (openssl rand -base64 32)
HMAC_SECRET=replace_with_32_bytes_base64

# Signup access code (min 12 chars, URL-safe random via openssl rand -base64 12)
SIGNUP_CODE=replace_with_12_plus_chars

# Cron auth (openssl rand -base64 32)
CRON_SECRET=replace_with_32_bytes_base64

# App timezone (IANA)
APP_TIMEZONE=America/New_York

# Admin email for cron failure notifications
ADMIN_EMAIL=admin@example.com

# Local Supabase Postgres URL (for tests)
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:55322/postgres
