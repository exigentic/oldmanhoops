# Loaded automatically by the Supabase CLI for `supabase start` and `supabase config push`.
# Copy to supabase/.env for local dev; set these in CI/prod environment for `config push`.

# Site URL used to build links in Supabase-sent emails (e.g. {{ .SiteURL }} in magic_link.html).
SUPABASE_AUTH_SITE_URL=http://devbox:3000

# Allow-list entry for auth redirects. Supabase supports the `**` wildcard suffix to cover
# all paths under an origin. For local dev a single `http://devbox:3000/**` covers /auth/confirm.
SUPABASE_AUTH_ADDITIONAL_REDIRECT_URLS=http://devbox:3000/**
